---
import { HeroCharacter, HeroCopy, HeroParticles } from "./react/HeroAnimations";
import { FallingLeaves } from "./react/particles/FallingLeaves";
---

<section
  id="top"
  class="relative min-h-dvh pt-35.5 flex flex-col justify-center pb-12 overflow-hidden"
>
  <div
    class="absolute inset-0 bg-center bg-cover"
    style={`background-image: url('${import.meta.env.BASE_URL}images/hero_bg.png')`}
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-0 [background:linear-gradient(90deg,rgba(5,5,5,0.95)_0%,rgba(5,5,5,0.60)_40%,rgba(5,5,5,0.15)_100%),linear-gradient(180deg,rgba(5,5,5,0.15)_0%,rgba(5,5,5,0.85)_100%)]"
    aria-hidden="true"
  >
  </div>

  <HeroParticles client:load />
  <FallingLeaves client:load />

  <div
    class="w-container-page mx-auto relative grid grid-cols-2 tablet:grid-cols-1 items-center gap-10"
  >
    <HeroCopy client:load />
    <HeroCharacter client:load />
  </div>
</section>
