---
import { HeroCharacter, HeroCopy, HeroParticles } from "./react/HeroAnimations";
---

<section id="top" class="relative min-h-dvh pt-[142px] flex flex-col justify-center pb-12">
  <div
    class="absolute inset-0 bg-[url('/hero-bg.png')] bg-center bg-cover"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-0 [background:linear-gradient(90deg,rgba(5,5,5,0.95)_0%,rgba(5,5,5,0.60)_40%,rgba(5,5,5,0.15)_100%),linear-gradient(180deg,rgba(5,5,5,0.15)_0%,rgba(5,5,5,0.85)_100%)]"
    aria-hidden="true"
  >
  </div>

  <HeroParticles client:load />

  <div
    class="w-[min(1160px,calc(100%-40px))] mx-auto relative grid grid-cols-[1fr_1fr] max-[980px]:grid-cols-1 items-center gap-10"
  >
    <HeroCopy client:load />
    <HeroCharacter client:load />
  </div>
</section>
