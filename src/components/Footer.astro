---
import { GAME } from "../consts";
import { SteamButtonAnimated } from "./react/SteamButtonAnimated";

const STEAM_DEVELOPER_URL =
  "https://store.steampowered.com/search/?developer=RDB%27s+Studio";
const ITCHIO_URL = "https://rdbs-studio.itch.io/";
const INSTAGRAM_URL = "https://www.instagram.com/birdyronin/";
const YOUTUBE_URL = "https://www.youtube.com/@BirdyRonin";
---

<footer class="border-t border-bamboo/20 bg-black py-12">
  <div class="w-[min(1160px,calc(100%_-_40px))] mx-auto">
    <div
      class="grid grid-cols-4 max-[980px]:grid-cols-2 max-[640px]:grid-cols-1 gap-10 items-start"
    >
      <!-- Col 1: Identity -->
      <div class="flex flex-col gap-4">
        <img
          src="/logo.png"
          alt="Byrd Ronin"
          class="w-full h-auto"
          loading="lazy"
        />
        <p class="text-muted/70 text-sm leading-relaxed font-body">
          Ação 2D intensa com combate preciso. Avance, evolua e sobreviva ao
          caos como um pássaro Ronin.
        </p>
      </div>

      <!-- Col 2: Site Map -->
      <nav
        class="flex flex-col gap-1 max-[980px]:mt-2 mx-auto"
        aria-label="Footer navigation"
      >
        <p
          class="text-[10px] font-display tracking-[0.18em] uppercase text-bamboo/50 mb-2"
        >
          Navegação
        </p>
        {
          (
            [
              ["#hero", "Início"],
              ["#trailer", "Trailer"],
              ["#features", "Features"],
              ["#gameplay", "Gameplay"],
            ] as const
          ).map(([href, label]) => (
            <a
              href={href}
              class="group flex items-center gap-2 py-1 text-muted font-display text-base tracking-[0.06em] hover:text-bamboo transition-colors duration-200"
            >
              <span class="w-3 h-px bg-muted/30 group-hover:bg-bamboo/60 group-hover:w-5 transition-all duration-200 inline-block" />
              {label}
            </a>
          ))
        }
      </nav>

      <!-- Col 3: Studio & Social -->
      <div class="flex flex-col gap-5">
        <img
          src="/rdb_studio_logo.png"
          alt="RDB's Studio"
          class="w-full max-w-40 h-auto"
          loading="lazy"
        />

        <div class="flex flex-col gap-3">
          <p
            class="text-[10px] font-display tracking-[0.18em] uppercase text-bamboo/50"
          >
            Redes
          </p>
          <div class="flex items-center gap-3">
            <!-- Instagram -->
            <a
              href={INSTAGRAM_URL}
              class="group flex items-center justify-center w-8 h-8 rounded border border-white/10 bg-white/3 text-muted hover:text-bamboo hover:border-bamboo/40 hover:bg-bamboo/5 transition-all duration-200"
              aria-label="Instagram"
              target="_blank"
              rel="noreferrer"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                ></path>
              </svg>
            </a>

            <!-- YouTube -->
            <a
              href={YOUTUBE_URL}
              class="group flex items-center justify-center w-8 h-8 rounded border border-white/10 bg-white/3 text-muted hover:text-bamboo hover:border-bamboo/40 hover:bg-bamboo/5 transition-all duration-200"
              aria-label="YouTube"
              target="_blank"
              rel="noreferrer"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                ></path>
              </svg>
            </a>

            <!-- Steam Developer -->
            <a
              href={STEAM_DEVELOPER_URL}
              class="group flex items-center justify-center w-8 h-8 rounded border border-white/10 bg-white/3 text-muted hover:text-bamboo hover:border-bamboo/40 hover:bg-bamboo/5 transition-all duration-200"
              aria-label="Steam — Página do desenvolvedor"
              target="_blank"
              rel="noreferrer"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.494 2.028-4.52 4.524-4.52 2.494 0 4.52 2.026 4.52 4.52s-2.026 4.52-4.52 4.52h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.606 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.455 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.662 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"
                ></path>
              </svg>
            </a>

            <!-- itch.io -->
            <a
              href={ITCHIO_URL}
              class="group flex items-center justify-center w-8 h-8 rounded border border-white/10 bg-white/3 text-muted hover:text-bamboo hover:border-bamboo/40 hover:bg-bamboo/5 transition-all duration-200"
              aria-label="itch.io"
              target="_blank"
              rel="noreferrer"
            >
              <img
                src="/itchio-logo-textless-white.svg"
                width="16"
                height="16"
                alt=""
                aria-hidden="true"
                class="w-4 h-4 object-contain"
              />
            </a>
          </div>
        </div>
      </div>

      <!-- Col 4: CTA -->
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1">
          <p
            class="text-[10px] font-display tracking-[0.18em] uppercase text-bamboo/50"
          >
            Jogar
          </p>
          <p class="text-muted/75 text-sm leading-snug font-body">
            Comece sua jornada como o pássaro Ronin. Disponível agora na Steam
          </p>
        </div>
        <SteamButtonAnimated
          label="JOGAR AGORA"
          event="steam_cta_footer_click"
          client:visible
        />
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-bamboo/10 mt-10 pt-6">
    <div
      class="w-[min(1160px,calc(100%-40px))] mx-auto flex items-center justify-center max-[640px]:flex-col max-[640px]:gap-2"
    >
      <p class="m-0 text-[11px] text-[rgba(184,202,219,0.35)] font-body">
        © {new Date().getFullYear()}
        {GAME.title} · {GAME.developer}. Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>
