---
import { AnimatedSectionHeader } from "./react/AnimatedSectionHeader";
import { FeatureGrid } from "./react/FeatureGrid";
import { ShurikenParticles } from "./react/particles/ShurikenParticles";
---

<section
  id="features"
  class="relative py-20"
  style="background-image: repeating-linear-gradient(0deg, rgba(107,143,94,0.07) 0px, rgba(107,143,94,0.07) 1px, transparent 1px, transparent 40px), repeating-linear-gradient(90deg, rgba(107,143,94,0.07) 0px, rgba(107,143,94,0.07) 1px, transparent 1px, transparent 40px);"
>
  <ShurikenParticles client:visible />

  <div class="w-container-page mx-auto relative z-10">
    <AnimatedSectionHeader
      eyebrow="Features"
      title="Domine cada run."
      client:visible
    />
    <FeatureGrid client:visible />
  </div>
</section>
