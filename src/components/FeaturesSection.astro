---
import { FeatureGrid } from "./react/FeatureGrid";
---

<section
  id="features"
  class="section-pad [background:linear-gradient(180deg,#091c2c,#050505)]"
>
  <div class="w-[min(1160px,calc(100%_-_40px))] mx-auto">
    <div class="max-w-[760px] mb-[42px]">
      <p class="mb-3.5 text-blue-light font-display text-xl uppercase">
        Features
      </p>
      <h2>Cada run pede timing mais afiado.</h2>
    </div>
    <FeatureGrid client:visible />
  </div>
</section>
