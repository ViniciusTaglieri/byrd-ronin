<section id="trailer" class="trailer-section section-pad">
  <div class="container narrow">
    <div class="section-heading centered">
      <p class="section-kicker">Watch the Trailer</p>
      <h2>See the blade rhythm before your first run.</h2>
      <p>Quick cuts, enemy pressure and upgrade momentum, framed like a Steam trailer slot and ready for the final embed.</p>
    </div>
    <button class="trailer-frame" type="button" data-event="trailer_play_click" aria-label="Play trailer">
      <img src="/page_bg_raw_gpt.png" alt="" width="1672" height="941" loading="lazy" />
      <span class="play-button" aria-hidden="true"></span>
      <span class="trailer-caption">Trailer coming soon - replace this frame with your Steam or YouTube embed.</span>
    </button>
  </div>
</section>
