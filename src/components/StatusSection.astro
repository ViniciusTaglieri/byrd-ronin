---
import { GAME } from "../consts";
import { SteamButtonAnimated } from "./react/SteamButtonAnimated";
import { StatusAnimations } from "./react/StatusAnimations";
import { BambooDecor } from "./react/BambooDecor";
---

<section id="status" class="relative z-[5] -mt-[72px]">
  <div class="container">
    <StatusAnimations client:visible>
      <div
        class="relative grid grid-cols-[1fr_0.92fr] max-[980px]:grid-cols-1 gap-[34px] p-[30px] max-[640px]:p-[22px] border border-bamboo/[0.35] rounded-2xl bg-gradient-to-br from-[rgba(13,26,15,0.97)] to-[rgba(11,18,16,0.97)] shadow-[4px_4px_0_rgba(107,143,94,0.45),0_32px_80px_rgba(0,0,0,0.5)] max-[640px]:shadow-[5px_5px_0_rgba(191,181,44,0.85)] overflow-hidden"
      >
        <BambooDecor
          side="right"
          opacity={0.10}
          style={{ position: "absolute", right: "8px", top: "50%", transform: "translateY(-50%)" }}
          client:load
        />

        <div class="flex flex-col justify-center">
          <p class="section-kicker">Available on Steam</p>
          <h2>Fast cuts, upgrades and bamboo-fueled chaos.</h2>
          <p>{GAME.descriptionShort}</p>
        </div>

        <div class="grid gap-5 content-center">
          <div class="flex flex-wrap gap-2" aria-label="Steam tags">
            {
              GAME.tags.map((tag) => (
                <span class="inline-block px-[10px] py-2 border border-bamboo/30 rounded text-[#eff8ff] bg-black/35 font-extrabold transition-[border-color,background] duration-[160ms] hover:border-bamboo/[0.55] hover:bg-bamboo/[0.12] cursor-default">
                  {tag}
                </span>
              ))
            }
          </div>

          <dl class="grid grid-cols-2 max-[640px]:grid-cols-1 gap-3 m-0">
            <div>
              <dt>Desenvolvedor</dt>
              <dd>{GAME.developer}</dd>
            </div>
            <div>
              <dt>Publisher</dt>
              <dd>{GAME.publisher}</dd>
            </div>
            <div>
              <dt>Lançamento</dt>
              <dd>{GAME.releaseDate}</dd>
            </div>
            <div>
              <dt>Preço</dt>
              <dd>{GAME.price}</dd>
            </div>
          </dl>

          <SteamButtonAnimated
            label="JOGAR AGORA"
            event="steam_cta_strip_click"
            className="max-[640px]:w-full"
            client:visible
          />
        </div>
      </div>
    </StatusAnimations>
  </div>
</section>
