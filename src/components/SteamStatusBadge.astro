---
import { GAME, STEAM_URL } from "../consts";
---

<div
  id="status"
  class="status-badge-wrap absolute bottom-0 left-0 right-0 z-20 flex justify-center px-5 translate-y-1/2 pointer-events-none"
>
  <a
    href={STEAM_URL}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${GAME.title} no Steam — ${GAME.price}`}
    class="steam-badge pointer-events-auto inline-flex flex-wrap items-center gap-x-5 gap-y-3 px-7 py-4 rounded-2xl border border-bamboo/20 shadow-[0_12px_40px_rgba(0,0,0,0.75),0_0_0_1px_rgba(107,143,94,0.06),inset_0_1px_0_rgba(255,255,255,0.04)] backdrop-blur-md cursor-pointer transition-all duration-300 hover:border-bamboo/40 hover:shadow-[0_12px_50px_rgba(0,0,0,0.85),0_0_28px_rgba(107,143,94,0.12)]"
    style="background: rgba(11,18,32,0.92);"
  >
    <!-- Steam icon + label -->
    <div class="flex items-center gap-2.5 shrink-0">
      <svg
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="text-[#49c2f2] shrink-0"
        aria-hidden="true"
      >
        <path
          d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.029 4.524 4.524s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.297-.249-1.887-.03l1.525.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012H7.54zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.252 0-2.265-1.014-2.265-2.265z"
        ></path>
      </svg>
      <span
        class="font-display text-sm uppercase tracking-[0.18em] text-bamboo font-semibold leading-none"
      >
        Available on Steam
      </span>
    </div>

    <!-- divider -->
    <div class="w-px h-5 bg-white/10 shrink-0 max-[540px]:hidden"></div>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1 max-[540px]:hidden shrink-0">
      {
        GAME.tags.map((tag) => (
          <span class="px-2.5 py-1 text-xs font-display rounded-full border border-bamboo/25 text-bamboo/65 bg-bamboo/8 leading-tight whitespace-nowrap">
            {tag}
          </span>
        ))
      }
    </div>

    <!-- divider -->
    <div class="w-px h-5 bg-white/10 shrink-0 max-[780px]:hidden"></div>

    <!-- Meta info -->
    <div class="flex items-center gap-2.5 text-xs max-[780px]:hidden shrink-0">
      <span class="text-white/40 font-body">{GAME.developer}</span>
      <span class="text-white/15">·</span>
      <span class="text-white/40 font-body">{GAME.releaseDate}</span>
    </div>

    <!-- Pulse indicator -->
    <div class="flex items-center gap-2 shrink-0 ml-1">
      <span class="relative flex h-2 w-2">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-bamboo opacity-60"
        ></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-bamboo/80"
        ></span>
      </span>
      <span
        class="text-xs text-bamboo/50 font-display uppercase tracking-wider leading-none"
      >
        Disponível
      </span>
    </div>
  </a>
</div>
