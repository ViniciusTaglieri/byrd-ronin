---
import { FallingLeaves } from "../components/react/FallingLeaves";
import { GAME, STEAM_URL } from "../consts";
import "../styles/global.css";

const {
  title = "Byrd Ronin - Action Roguelite on Steam",
  description = "Slice through bamboo, survive enemy waves and master chaotic roguelite runs in Byrd Ronin. Available now on Steam.",
} = Astro.props;

const schemaOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "VideoGame",
  name: GAME.title,
  description: GAME.descriptionShort,
  publisher: { "@type": "Organization", name: GAME.publisher },
  developer: { "@type": "Organization", name: GAME.developer },
  genre: ["Action", "Roguelite", "Hack and Slash", "Indie"],
  operatingSystem: "Windows",
  url: STEAM_URL,
  offers: {
    "@type": "Offer",
    price: "9.99",
    priceCurrency: "BRL",
    availability: "https://schema.org/InStock",
  },
});
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />
    <link rel="canonical" href="https://byrdronin.com" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Fast cuts, upgrades, enemies and chaos. Byrd Ronin now on Steam."
    />
    <meta property="og:image" content="https://byrdronin.com/og_image.png" />
    <meta property="og:url" content="https://byrdronin.com" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://byrdronin.com/og_image.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.ico" />

    <!-- Preload hero background for LCP -->
    <link rel="preload" as="image" href="/hero-bg.png" />


    <title>{title}</title>

    <!-- Schema.org -->
    <script type="application/ld+json" is:inline set:html={schemaOrg} />
  </head>
  <body class="antialiased min-h-dvh text-white font-body bg-black">
    <FallingLeaves mode="ambient" count={16} client:load />
    <slot />
  </body>
</html>
